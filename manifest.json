{
  "manifest_version": 3,
  "name": "X关注状态检测助手",
  "version": "1.0",
  "description": "自动检测 X (Twitter) 上的双向关注和未回关用户，并进行背景颜色标注。",
  "author": "pingoo.trade",
  "homepage_url": "https://pingoo.trade",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["x.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}